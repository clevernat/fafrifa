# Large/intermediate scientific data — do NOT commit real model output or
# regenerated production datasets. The small synthetic demo dataset under
# deliverable-2-dataset/demo_output/ IS committed intentionally (it is a
# deliverable), so it is force-kept below.
indices_dataset/
*.nc
*.zarr/
*.grib
*.grb

# Keep the committed synthetic demo outputs (override the *.nc/data rules above)
!deliverable-2-dataset/demo_output/*.npz
!deliverable-2-dataset/demo_output/*.csv
!deliverable-2-dataset/demo_output/figs/*.png

# Run logs / scratch
*.log
run.log
